# Lead Scraper Agent - Environment Variables

# Lead Source Configuration
# Options: apify, apollo, google_places
LEAD_SOURCE=apify

# Apify Configuration
APIFY_API_TOKEN=your_apify_token_here
APIFY_ACTOR_ID=your_actor_id_here

# Apollo.io Configuration
APOLLO_API_KEY=your_apollo_key_here

# Google Places API Configuration
GOOGLE_PLACES_API_KEY=your_google_places_key_here

# Google Sheets Configuration
GOOGLE_SHEETS_CREDENTIALS_PATH=./credentials/google_sheets_key.json
GOOGLE_SHEET_ID=your_sheet_id_here
GOOGLE_SHEET_TAB_NAME=Leads

# Notion Configuration (Optional)
NOTION_API_TOKEN=your_notion_token_here
NOTION_DATABASE_ID=your_database_id_here

# Output Configuration
# Options: csv, json, google_sheets, notion, all
OUTPUT_FORMAT=google_sheets

# Local output directory (if CSV/JSON)
OUTPUT_DIR=./output

# Deduplication
DEDUPE_FILE=./data/leads_history.json

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs

# API Rate Limiting
MAX_RETRIES=3
RETRY_DELAY=5

# Email Notifications (Optional)
ENABLE_EMAIL_ALERTS=false
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL=alerts@example.com
